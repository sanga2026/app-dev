# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=$Teddy@bank
DB_DATABASE=banking_os_core

# ─────────────────────────────────────────
# JWT SECURITY
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=super_secret_jwt_access_token_seed_random_string
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_seed_random_string
JWT_EXPIRATION=8h
REFRESH_TOKEN_EXPIRATION=7d

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# ─────────────────────────────────────────
# SUPER ADMIN SEED CREDENTIALS
# Change these before running npm run seed
# ─────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@banking-os.com
SUPER_ADMIN_PASSWORD=Admin@12345

# ─────────────────────────────────────────
# MAIL  (optional — for password reset flow)
# ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@banking-os.com
