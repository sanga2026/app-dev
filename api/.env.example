# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<your_postgres_password>
DB_DATABASE=banking_os_core

# ─────────────────────────────────────────
# JWT SECURITY  (generate 32+ random chars)
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=<change_me_random_32_chars_access>
JWT_REFRESH_SECRET=<change_me_random_32_chars_refresh>
JWT_EXPIRATION=8h
REFRESH_TOKEN_EXPIRATION=7d

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# ─────────────────────────────────────────
# MAIL  (optional — for password reset)
# ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=<your_email@gmail.com>
MAIL_PASS=<your_app_password>
MAIL_FROM=noreply@banking-os.com
